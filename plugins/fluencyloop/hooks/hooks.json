{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/refresh-marketplace.sh\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path $env:PLUGIN_ROOT 'hooks\\refresh-marketplace.ps1')\"",
            "timeout": 30,
            "statusMessage": "Checking FluencyLoop updates"
          }
        ]
      }
    ]
  }
}
